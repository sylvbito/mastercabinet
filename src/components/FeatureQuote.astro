---
interface Props {
  quote?: string;
  name?: string;
  role?: string;
}

const {
  quote = 'MasterCabinet transformed our outdated kitchen into something we never want to leave. The online design tool helped us visualise everything before we committed — made the whole process feel effortless.',
  name = 'Sarah Chen',
  role = 'Kitchen renovation, Brighton'
} = Astro.props;
---

<section class="feature-quote">
  <div class="container position-relative">
    <div class="feature-quote__layout grid-12">
      <div class="feature-quote__mark" aria-hidden="true">
        <span>&ldquo;</span>
      </div>
      <div class="feature-quote__body">
        <blockquote>
          <p>{quote}</p>
        </blockquote>
      </div>
      <div class="feature-quote__attribution">
        <strong>{name}</strong>
        {role && <span>{role}</span>}
      </div>
    </div>
  </div>
</section>

<style>
  .feature-quote {
    padding-block: var(--section-y);
    background: var(--color-section);
    position: relative;
  }

  .feature-quote__layout {
    row-gap: var(--space-5);
    align-items: center;
  }

  .feature-quote__mark {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: calc(var(--gutter) - 1rem);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-primary);
    color: var(--brand-primary-contrast);
  }

  .feature-quote__mark span {
    font-size: 3rem;
    line-height: 1;
    font-family: Georgia, serif;
  }

  .feature-quote__body {
    grid-column: 2 / span 8;
    position: relative;
    padding-right: var(--space-6);
  }

  .feature-quote__body::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border);
  }

  .feature-quote__body blockquote {
    margin: 0;
  }

  .feature-quote__body blockquote p {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-heading);
    margin: 0;
    quotes: none;
    max-width: 40rem;
  }

  .feature-quote__attribution {
    grid-column: 10 / span 3;
    text-align: right;
  }

  .feature-quote__attribution strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: var(--space-1);
  }

  .feature-quote__attribution span {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 820px) {
    .feature-quote__mark {
      grid-column: 1 / span 2;
    }

    .feature-quote__body {
      grid-column: 3 / span 9;
    }

    .feature-quote__attribution {
      grid-column: 3 / span 9;
      text-align: left;
    }

    .feature-quote__body blockquote p {
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .feature-quote__layout {
      text-align: center;
    }

    .feature-quote__mark {
      position: static;
      grid-column: 1;
      width: 4rem;
      height: 4rem;
      margin-inline: auto;
    }

    .feature-quote__body,
    .feature-quote__attribution {
      grid-column: 1;
      text-align: center;
    }

    .feature-quote__body {
      padding-right: 0;
    }

    .feature-quote__body::after {
      content: none;
    }
  }
</style>
