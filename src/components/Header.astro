---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  site: {
    name: string;
    ctaLabel?: string;
    ctaUrl?: string;
  };
  pathname: string;
}

const { site, pathname } = Astro.props;
const nav: { label: string; href: string; exact?: boolean }[] = [
  { label: 'Services', href: '/services/', exact: true },
  { label: 'Gallery', href: '/services/' },
  { label: 'Process', href: '/#process' },
  { label: 'Contact', href: '/contact/' }
];

const isCurrent = (item: { label: string; href: string; exact?: boolean }) => {
  if (item.href.startsWith('/#')) return false;
  if (item.exact) return pathname === item.href;
  return pathname === item.href || pathname.startsWith(item.href);
};
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label={`${site.name} home`}>
      <span class="brand-lockup">
        <span class="brand-lockup__primary">
          <span class="brand-lockup__first">Master</span>
          <span class="brand-lockup__second">Cabinet</span>
        </span>
      </span>
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={item.href} aria-current={isCurrent(item) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    {site.ctaLabel && site.ctaUrl && (
      <a href={site.ctaUrl} class="site-header__cta">
        {site.ctaLabel} &rarr;
      </a>
    )}
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-page);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    min-height: 5rem;
    gap: var(--space-4);
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .site-header__brand:hover {
    opacity: 0.75;
  }

  .brand-lockup {
    display: inline-flex;
    align-items: baseline;
    gap: 0.08em;
    line-height: 1;
  }

  .brand-lockup__primary {
    display: flex;
    gap: 0.08em;
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }

  .brand-lockup__first {
    color: var(--brand-primary);
  }

  .brand-lockup__second {
    color: var(--color-ink);
  }

  .site-header__nav {
    display: flex;
    justify-content: center;
    flex: 1 1 auto;
    gap: var(--space-5);
    align-items: center;
  }

  .site-header__nav a {
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    color: var(--brand-primary);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem 0.6rem 1.15rem;
    background: var(--brand-primary);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    line-height: 1;
    flex-shrink: 0;
    transition: filter 0.2s ease;
  }

  .site-header__cta:hover {
    filter: brightness(1.15);
    color: #fff;
  }

  @media (max-width: 760px) {
    .site-header__inner {
      flex-wrap: wrap;
      gap: var(--space-3);
      padding-block: var(--space-3);
      min-height: auto;
    }

    .site-header__logo {
      height: 2rem;
    }

    .site-header__nav {
      flex: 1 1 100%;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-2) var(--space-3);
      order: 2;
    }

    .site-header__nav a {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
    }

    .site-header__cta {
      font-size: 0.7rem;
      padding: 0.45rem 0.85rem 0.45rem 1rem;
      order: 3;
    }
  }
</style>
