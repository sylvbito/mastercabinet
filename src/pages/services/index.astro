---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/PageIntro.astro';
import Section from '@components/Section.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import CTABand from '@components/CTABand.astro';
import { byOrder } from '../../lib/content';

const services = byOrder(await getCollection('services'));
---

<BaseLayout title="Services" description="Custom cabinetry services from MasterCabinet — kitchens, bathrooms, laundries, wardrobes, and joinery.">
  <PageIntro
    eyebrow="Services"
    title="What we build"
    intro="Every room has different demands. We design and build cabinetry that suits the space, the use, and the way you live."
  />

  <Section>
    <ServiceGrid services={services} />
  </Section>

  <CTABand
    title="Not sure where to start?"
    text="Send us a brief description of your project and we will recommend the right approach — no obligation."
  />
</BaseLayout>
